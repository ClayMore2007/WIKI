{
  "language": "zh",
  "duration": 321.015875,
  "segments": [
    {
      "start": 0.0,
      "end": 1.4,
      "text": "今年会长到发风了"
    },
    {
      "start": 1.4,
      "end": 3.68,
      "text": "五大超级黑马塞到有点冷门"
    },
    {
      "start": 3.68,
      "end": 6.0,
      "text": "但每一个都是确定性最强"
    },
    {
      "start": 6.0,
      "end": 7.68,
      "text": "空间最大的超级风口"
    },
    {
      "start": 7.68,
      "end": 9.72,
      "text": "而且现在还没被市场充分关注"
    },
    {
      "start": 9.72,
      "end": 11.72,
      "text": "正是布局的黄金时期"
    },
    {
      "start": 11.72,
      "end": 12.6,
      "text": "如果错过"
    },
    {
      "start": 12.6,
      "end": 13.68,
      "text": "你将会后悔一辈子"
    },
    {
      "start": 13.68,
      "end": 14.32,
      "text": "首先"
    },
    {
      "start": 14.32,
      "end": 16.2,
      "text": "第一批要重点关注的黑马"
    },
    {
      "start": 16.2,
      "end": 17.0,
      "text": "就是探线位"
    },
    {
      "start": 17.0,
      "end": 18.8,
      "text": "很多朋友对探线位的认知还挺有"
    },
    {
      "start": 18.8,
      "end": 21.08,
      "text": "在高端自行车架与毛球拍上"
    },
    {
      "start": 21.08,
      "end": 23.56,
      "text": "但在整个高端制造体系里"
    },
    {
      "start": 23.56,
      "end": 25.68,
      "text": "它是无可替代的工业经股"
    },
    {
      "start": 25.68,
      "end": 27.8,
      "text": "商业航天的火箭主体股价"
    },
    {
      "start": 27.8,
      "end": 30.48,
      "text": "人型机器人关节的核心周程"
    },
    {
      "start": 30.48,
      "end": 33.16,
      "text": "先进军工装备的核心结构件"
    },
    {
      "start": 33.16,
      "end": 34.84,
      "text": "甚至大飞机的机身材料"
    },
    {
      "start": 34.84,
      "end": 36.6,
      "text": "都离不开高端探线位"
    },
    {
      "start": 36.6,
      "end": 37.4,
      "text": "可以说"
    },
    {
      "start": 37.4,
      "end": 39.56,
      "text": "未来中国的高端制造升级"
    },
    {
      "start": 39.56,
      "end": 40.4,
      "text": "缺了探线位"
    },
    {
      "start": 40.4,
      "end": 42.44,
      "text": "就等于失去了核心股价和支撑"
    },
    {
      "start": 42.44,
      "end": 43.96,
      "text": "根本无从发展"
    },
    {
      "start": 43.96,
      "end": 45.08,
      "text": "从格局上看"
    },
    {
      "start": 45.08,
      "end": 48.04,
      "text": "当前全球70%以上的高端探线位"
    },
    {
      "start": 48.04,
      "end": 49.44,
      "text": "产能被日本动力"
    },
    {
      "start": 49.44,
      "end": 51.8,
      "text": "东邦这少数几家投不企业垄断"
    },
    {
      "start": 51.8,
      "end": 53.96,
      "text": "核心生产工艺关键设备"
    },
    {
      "start": 53.96,
      "end": 56.6,
      "text": "下游客户认证体系都有极高的闭脸"
    },
    {
      "start": 56.6,
      "end": 59.04,
      "text": "国内企业短期很难实现全面突破"
    },
    {
      "start": 59.04,
      "end": 62.12,
      "text": "错在需求端已经赢来了爆发式增长"
    },
    {
      "start": 62.12,
      "end": 64.64,
      "text": "商业航天进入高密度发射周期"
    },
    {
      "start": 64.64,
      "end": 67.88,
      "text": "人型机器人进入量产落地关键器"
    },
    {
      "start": 67.88,
      "end": 69.52,
      "text": "国内高端装备全面升级"
    },
    {
      "start": 69.52,
      "end": 71.16,
      "text": "三大领域集中强调"
    },
    {
      "start": 71.16,
      "end": 73.12,
      "text": "直接造成了国内高端探线位"
    },
    {
      "start": 73.12,
      "end": 75.16,
      "text": "1.25万噸的粘度缺口"
    },
    {
      "start": 75.16,
      "end": 76.76,
      "text": "缺口率高达90%"
    },
    {
      "start": 76.76,
      "end": 77.72,
      "text": "更关键的是"
    },
    {
      "start": 77.72,
      "end": 80.32,
      "text": "攻击端完全跟不上需求的爆发"
    },
    {
      "start": 80.32,
      "end": 81.84,
      "text": "高端探线位生产线"
    },
    {
      "start": 81.84,
      "end": 83.0,
      "text": "从设备调势"
    },
    {
      "start": 83.0,
      "end": 85.72,
      "text": "工艺打磨到下游客户的认证通过"
    },
    {
      "start": 85.72,
      "end": 87.72,
      "text": "整个周期最快要两年"
    },
    {
      "start": 87.72,
      "end": 89.72,
      "text": "也就是说未来两年内"
    },
    {
      "start": 89.72,
      "end": 92.08,
      "text": "这个供需缺口根本无法填补"
    },
    {
      "start": 92.08,
      "end": 93.2,
      "text": "刚性需求拉满"
    },
    {
      "start": 93.2,
      "end": 94.56,
      "text": "供急触及天花板"
    },
    {
      "start": 94.56,
      "end": 96.36,
      "text": "这种格局就是资本市场里"
    },
    {
      "start": 96.36,
      "end": 97.96,
      "text": "最硬的上涨逻辑"
    },
    {
      "start": 97.96,
      "end": 100.6,
      "text": "今年谁能率先突破记住地类"
    },
    {
      "start": 100.6,
      "end": 102.28,
      "text": "锁定稳定会员"
    },
    {
      "start": 102.28,
      "end": 104.28,
      "text": "谁就能掌握真金白银"
    },
    {
      "start": 104.28,
      "end": 105.16,
      "text": "第二批黑马"
    },
    {
      "start": 105.16,
      "end": 106.08,
      "text": "AF白板"
    },
    {
      "start": 106.08,
      "end": 107.56,
      "text": "专用特种波线部"
    },
    {
      "start": 107.56,
      "end": 109.52,
      "text": "AI服务器的核心命满"
    },
    {
      "start": 109.52,
      "end": 111.64,
      "text": "今年AI主线吵了一波又一波"
    },
    {
      "start": 111.64,
      "end": 113.52,
      "text": "从大模型到AI芯片"
    },
    {
      "start": 113.52,
      "end": 115.08,
      "text": "再到HPM内存"
    },
    {
      "start": 115.08,
      "end": 116.52,
      "text": "但很多人都忽略了"
    },
    {
      "start": 116.52,
      "end": 119.28,
      "text": "AI算力真正的卡伯子环节藏在最"
    },
    {
      "start": 119.28,
      "end": 120.96,
      "text": "最上游的原材料里"
    },
    {
      "start": 120.96,
      "end": 123.48,
      "text": "AI服务器跑大模型做高速运算"
    },
    {
      "start": 123.48,
      "end": 125.64,
      "text": "全靠ABF再版来实现"
    },
    {
      "start": 125.64,
      "end": 127.96,
      "text": "芯片之间的高速信号传输"
    },
    {
      "start": 127.96,
      "end": 129.36,
      "text": "而特种波线部"
    },
    {
      "start": 129.36,
      "end": 132.64,
      "text": "正是ABF再版的核心增强原材料"
    },
    {
      "start": 132.64,
      "end": 134.44,
      "text": "它对材料的热膨脏系数"
    },
    {
      "start": 134.44,
      "end": 137.2,
      "text": "平整度稳定性有极致的要求"
    },
    {
      "start": 137.2,
      "end": 138.32,
      "text": "技术比类极高"
    },
    {
      "start": 138.32,
      "end": 140.48,
      "text": "没有合格的特种波线部"
    },
    {
      "start": 140.48,
      "end": 142.8,
      "text": "ABF再版的两率根本提不上来"
    },
    {
      "start": 142.8,
      "end": 144.4,
      "text": "哪怕你有再强的AI芯片"
    },
    {
      "start": 144.44,
      "end": 146.16,
      "text": "也无法正常传输数据"
    },
    {
      "start": 146.16,
      "end": 147.08,
      "text": "形同虚舍"
    },
    {
      "start": 147.08,
      "end": 149.2,
      "text": "目前全球90%的市场份额"
    },
    {
      "start": 149.2,
      "end": 150.6,
      "text": "被日本企业牢牢掌控"
    },
    {
      "start": 150.6,
      "end": 153.08,
      "text": "国内几乎没有稳定的规模化产能"
    },
    {
      "start": 153.08,
      "end": 154.84,
      "text": "而且新增的有效产能"
    },
    {
      "start": 154.84,
      "end": 157.12,
      "text": "最快要到2027年才能释放"
    },
    {
      "start": 157.12,
      "end": 157.96,
      "text": "也就是说"
    },
    {
      "start": 157.96,
      "end": 160.36,
      "text": "今年的攻击已经被彻底锁死"
    },
    {
      "start": 160.36,
      "end": 162.92,
      "text": "但需求端却随着全球AI大模型的"
    },
    {
      "start": 162.92,
      "end": 163.88,
      "text": "全面爆发"
    },
    {
      "start": 163.88,
      "end": 166.6,
      "text": "AI服务器的大规模装机持续暴涨"
    },
    {
      "start": 166.6,
      "end": 169.04,
      "text": "瑞营都发布报告预测"
    },
    {
      "start": 169.04,
      "end": 170.8,
      "text": "特种波线部的涨价"
    },
    {
      "start": 170.8,
      "end": 173.08,
      "text": "行程将一直延续到2027年"
    },
    {
      "start": 173.08,
      "end": 174.56,
      "text": "而且价格会对上条"
    },
    {
      "start": 174.56,
      "end": 175.68,
      "text": "是AI算"
    },
    {
      "start": 175.68,
      "end": 176.68,
      "text": "可爆发周期里"
    },
    {
      "start": 176.68,
      "end": 178.84,
      "text": "最确定的上游受益方向"
    },
    {
      "start": 178.84,
      "end": 180.04,
      "text": "第三批黑马"
    },
    {
      "start": 180.04,
      "end": 181.72,
      "text": "高端探酸被粉体"
    },
    {
      "start": 181.72,
      "end": 183.52,
      "text": "它是电子工业大米"
    },
    {
      "start": 183.52,
      "end": 185.4,
      "text": "MLCC的核心原材料"
    },
    {
      "start": 185.4,
      "end": 187.32,
      "text": "占粉体成本90%以上"
    },
    {
      "start": 187.32,
      "end": 190.24,
      "text": "从手机电脑到AI服务器"
    },
    {
      "start": 190.24,
      "end": 191.12,
      "text": "新能源车"
    },
    {
      "start": 191.12,
      "end": 192.72,
      "text": "所有电子坎品都离不开它"
    },
    {
      "start": 192.72,
      "end": 195.4,
      "text": "全球90%高端产能被日本垄断"
    },
    {
      "start": 195.4,
      "end": 197.4,
      "text": "国内自己率不足10%"
    },
    {
      "start": 197.4,
      "end": 198.84,
      "text": "几乎全靠进口"
    },
    {
      "start": 198.84,
      "end": 200.6,
      "text": "需求端直接爆发"
    },
    {
      "start": 200.72,
      "end": 203.64,
      "text": "新能源车MLC用量是手机的5到10倍"
    },
    {
      "start": 203.64,
      "end": 206.44,
      "text": "AI服务器是普通服务器的3倍"
    },
    {
      "start": 206.44,
      "end": 208.32,
      "text": "叠加入型机器人"
    },
    {
      "start": 208.32,
      "end": 209.52,
      "text": "军工增量需求"
    },
    {
      "start": 209.52,
      "end": 211.04,
      "text": "增速超35%"
    },
    {
      "start": 211.04,
      "end": 212.28,
      "text": "技术必累拉满"
    },
    {
      "start": 212.28,
      "end": 214.52,
      "text": "下游任正要18到24个月"
    },
    {
      "start": 214.52,
      "end": 216.92,
      "text": "现在擴产也要2年后才有产能"
    },
    {
      "start": 216.92,
      "end": 218.96,
      "text": "供需缺口超90%"
    },
    {
      "start": 218.96,
      "end": 221.96,
      "text": "涨价加国产替代的确定性直接拉满"
    },
    {
      "start": 221.96,
      "end": 223.12,
      "text": "第4批黑马"
    },
    {
      "start": 223.12,
      "end": 226.36,
      "text": "凌化音光芯片的核心趁底材料"
    },
    {
      "start": 226.36,
      "end": 229.0,
      "text": "高端光模块的制造必须以凌化"
    },
    {
      "start": 229.0,
      "end": 230.8,
      "text": "因为趁底缺一不可"
    },
    {
      "start": 230.8,
      "end": 233.84,
      "text": "目前日美企业占据90%以上的产能"
    },
    {
      "start": 233.84,
      "end": 235.28,
      "text": "国内高度依赖进口"
    },
    {
      "start": 235.28,
      "end": 236.84,
      "text": "长期被卡薄子"
    },
    {
      "start": 236.84,
      "end": 238.44,
      "text": "伴随AI算力爆发"
    },
    {
      "start": 238.44,
      "end": 239.12,
      "text": "光模"
    },
    {
      "start": 239.12,
      "end": 242.68,
      "text": "在需求风涨全球供需缺口高达70%"
    },
    {
      "start": 242.68,
      "end": 246.44,
      "text": "同时采中AI算力和国产替代双重风口爆发前"
    },
    {
      "start": 246.44,
      "end": 248.44,
      "text": "利拉满最后一批黑马"
    },
    {
      "start": 248.44,
      "end": 251.68,
      "text": "营高大功率电子设备的核心风涨材料"
    },
    {
      "start": 251.68,
      "end": 254.24,
      "text": "它主要用在新能源车高压快充"
    },
    {
      "start": 254.24,
      "end": 257.24,
      "text": "光服探化规期间的高端风庄里"
    },
    {
      "start": 257.24,
      "end": 260.28,
      "text": "现在新能源车全面向高压快充升级"
    },
    {
      "start": 260.28,
      "end": 262.56,
      "text": "光服装击量持续暴增"
    },
    {
      "start": 262.56,
      "end": 264.64,
      "text": "探化规期间需求直接表声"
    },
    {
      "start": 264.64,
      "end": 267.8,
      "text": "作为核心材料的营高需求也会同步放量"
    },
    {
      "start": 267.8,
      "end": 271.24,
      "text": "是新能源塞道里被严重低估的隐形冠军"
    },
    {
      "start": 271.24,
      "end": 274.84,
      "text": "这五大塞道都具备三个共同的硬核逻辑"
    },
    {
      "start": 274.84,
      "end": 277.24,
      "text": "第一 海外巨头龙断锁死"
    },
    {
      "start": 277.24,
      "end": 278.96,
      "text": "攻击短期无法突破"
    },
    {
      "start": 278.96,
      "end": 280.84,
      "text": "第二 产业刚需爆发"
    },
    {
      "start": 280.84,
      "end": 283.0,
      "text": "供需缺口持续放大"
    },
    {
      "start": 283.0,
      "end": 284.76,
      "text": "第三 技术庇类极高"
    },
    {
      "start": 284.76,
      "end": 286.2,
      "text": "新玩家很难进场"
    },
    {
      "start": 286.2,
      "end": 288.72,
      "text": "同时还跌加了国家战略产业爆发"
    },
    {
      "start": 288.72,
      "end": 291.4,
      "text": "国产替代三重红力是今年价格最硬"
    },
    {
      "start": 291.4,
      "end": 293.32,
      "text": "行情最稳的财富风口"
    },
    {
      "start": 293.32,
      "end": 294.72,
      "text": "对我们普通人而言"
    },
    {
      "start": 294.72,
      "end": 296.32,
      "text": "布局这五大塞道"
    },
    {
      "start": 296.32,
      "end": 298.48,
      "text": "只需要把我两点核心"
    },
    {
      "start": 298.48,
      "end": 300.48,
      "text": "一是不忙目追高各股"
    },
    {
      "start": 300.48,
      "end": 302.68,
      "text": "先吃透塞道的底层逻辑"
    },
    {
      "start": 302.68,
      "end": 305.2,
      "text": "紧抓供需缺口国产替代"
    },
    {
      "start": 305.2,
      "end": 307.0,
      "text": "技术庇类这三大核心"
    },
    {
      "start": 307.0,
      "end": 309.12,
      "text": "先选对塞道再选对标的"
    },
    {
      "start": 309.12,
      "end": 311.16,
      "text": "二是专业塞道不要硬扛"
    },
    {
      "start": 311.16,
      "end": 312.56,
      "text": "不要平感觉虾满"
    },
    {
      "start": 312.56,
      "end": 314.48,
      "text": "借助成熟的投延体系"
    },
    {
      "start": 314.48,
      "end": 315.48,
      "text": "借力发力"
    },
    {
      "start": 315.48,
      "end": 317.48,
      "text": "才能稳稳抓住这波波的基因"
    }
  ]
