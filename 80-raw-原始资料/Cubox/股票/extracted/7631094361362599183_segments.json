{
  "language": "zh",
  "duration": 190.984125,
  "segments": [
    {
      "start": 0.0,
      "end": 2.36,
      "text": "我们团队调研书里了深藤核心供应链"
    },
    {
      "start": 2.36,
      "end": 3.6,
      "text": "今天不铺太开"
    },
    {
      "start": 3.6,
      "end": 4.68,
      "text": "就只讲四款"
    },
    {
      "start": 4.68,
      "end": 5.36,
      "text": "风装"
    },
    {
      "start": 5.36,
      "end": 6.16,
      "text": "测试"
    },
    {
      "start": 6.16,
      "end": 6.92,
      "text": "连接器"
    },
    {
      "start": 6.92,
      "end": 7.76,
      "text": "光磨快"
    },
    {
      "start": 7.76,
      "end": 8.84,
      "text": "一个视频带你看清"
    },
    {
      "start": 8.84,
      "end": 10.64,
      "text": "现在那些公司处在什么位置上"
    },
    {
      "start": 10.64,
      "end": 11.72,
      "text": "先看风装"
    },
    {
      "start": 11.72,
      "end": 13.56,
      "text": "现在国内给深藤做风装"
    },
    {
      "start": 13.56,
      "end": 14.92,
      "text": "核心还是盛合金"
    },
    {
      "start": 14.92,
      "end": 16.68,
      "text": "为通负和取两这三家"
    },
    {
      "start": 16.68,
      "end": 19.0,
      "text": "这里面盛合金威是最关键的一款"
    },
    {
      "start": 19.0,
      "end": 21.64,
      "text": "深藤在盛合金威的产能站比是很高的"
    },
    {
      "start": 21.64,
      "end": 23.96,
      "text": "基本站到同期总产能的八成以上"
    },
    {
      "start": 23.96,
      "end": 26.08,
      "text": "盛合金威一个月大概六千多片"
    },
    {
      "start": 26.08,
      "end": 28.6,
      "text": "深藤用了接近四千到四千五百片"
    },
    {
      "start": 28.64,
      "end": 30.84,
      "text": "从深藤自己的整体出货结构来看"
    },
    {
      "start": 30.84,
      "end": 32.48,
      "text": "盛合金威风出来的芯片"
    },
    {
      "start": 32.48,
      "end": 34.28,
      "text": "站比大概在六成左右"
    },
    {
      "start": 34.28,
      "end": 35.12,
      "text": "通负这边"
    },
    {
      "start": 35.12,
      "end": 37.44,
      "text": "深藤目前大概用了約一千五百片"
    },
    {
      "start": 37.44,
      "end": 39.2,
      "text": "巨量总产能接近四千片"
    },
    {
      "start": 39.2,
      "end": 40.6,
      "text": "但现在量率还偏低"
    },
    {
      "start": 40.6,
      "end": 42.52,
      "text": "所以深藤给到它的量不算大"
    },
    {
      "start": 42.52,
      "end": 43.84,
      "text": "大概是一千多片"
    },
    {
      "start": 43.84,
      "end": 45.76,
      "text": "后面这个分配思路其实也很清楚"
    },
    {
      "start": 45.76,
      "end": 47.88,
      "text": "深藤是有一枉巨量清写的"
    },
    {
      "start": 47.88,
      "end": 49.68,
      "text": "因为巨量是重点扶持对象"
    },
    {
      "start": 49.68,
      "end": 51.92,
      "text": "只是现阶段深合金威的量率还是最好"
    },
    {
      "start": 51.92,
      "end": 53.88,
      "text": "后面如果巨量往扣握SL走"
    },
    {
      "start": 53.88,
      "end": 54.84,
      "text": "量去起来了"
    },
    {
      "start": 54.84,
      "end": 55.64,
      "text": "他拿到的份额"
    },
    {
      "start": 55.64,
      "end": 56.88,
      "text": "大概率会继续往上走"
    },
    {
      "start": 56.88,
      "end": 57.96,
      "text": "再看测试"
    },
    {
      "start": 58.08,
      "end": 60.24,
      "text": "深藤现在测试环节的主力是偽测"
    },
    {
      "start": 60.24,
      "end": 62.96,
      "text": "这家公司大概吃掉了整体测试产能的漆尘"
    },
    {
      "start": 62.96,
      "end": 63.84,
      "text": "剩下的里面"
    },
    {
      "start": 63.84,
      "end": 65.56,
      "text": "长电科技占了百分之十几"
    },
    {
      "start": 65.56,
      "end": 67.4,
      "text": "通负也分到了一部分测试也无"
    },
    {
      "start": 67.4,
      "end": 69.4,
      "text": "这个环节眼下还看不出明显平静"
    },
    {
      "start": 69.4,
      "end": 70.96,
      "text": "至少从专家反馈来看"
    },
    {
      "start": 70.96,
      "end": 72.92,
      "text": "测试不是当前最卡的地方"
    },
    {
      "start": 72.92,
      "end": 73.8,
      "text": "设备层面"
    },
    {
      "start": 73.8,
      "end": 76.4,
      "text": "深藤现在主要还是依赖常穿科技的设备"
    },
    {
      "start": 76.4,
      "end": 77.36,
      "text": "来测大芯片"
    },
    {
      "start": 77.36,
      "end": 79.12,
      "text": "不是因为别的设备完全不能用"
    },
    {
      "start": 79.12,
      "end": 81.4,
      "text": "而是因为向爱德万93K这类设备"
    },
    {
      "start": 81.4,
      "end": 83.12,
      "text": "虽然性能上能满足要求"
    },
    {
      "start": 83.12,
      "end": 84.8,
      "text": "但一次能测的数量偏小"
    },
    {
      "start": 84.8,
      "end": 86.16,
      "text": "测试时间也偏长"
    },
    {
      "start": 86.16,
      "end": 87.4,
      "text": "所以实际落地下来"
    },
    {
      "start": 87.4,
      "end": 89.0,
      "text": "测试产更依赖常穿科技"
    },
    {
      "start": 89.0,
      "end": 90.28,
      "text": "还有一点也得看到"
    },
    {
      "start": 90.28,
      "end": 92.28,
      "text": "深藤确实在往古产设备期"
    },
    {
      "start": 92.28,
      "end": 95.32,
      "text": "但华峰设备现在还是试点和小批量验证阶段"
    },
    {
      "start": 95.32,
      "end": 96.72,
      "text": "还没有大规模商量"
    },
    {
      "start": 96.72,
      "end": 98.2,
      "text": "中远期看测试的大头"
    },
    {
      "start": 98.2,
      "end": 100.64,
      "text": "大概率还是会留在偽测和常电科技手里"
    },
    {
      "start": 100.64,
      "end": 101.96,
      "text": "然后是连接器"
    },
    {
      "start": 101.96,
      "end": 103.48,
      "text": "这个环节现在有个变化"
    },
    {
      "start": 103.48,
      "end": 106.92,
      "text": "就是航天电器已经进了深藤的连接器供应体系"
    },
    {
      "start": 106.92,
      "end": 108.68,
      "text": "只是它具体的拿多少份额"
    },
    {
      "start": 108.68,
      "end": 110.36,
      "text": "材料里说现在还没完全定"
    },
    {
      "start": 110.36,
      "end": 111.92,
      "text": "预计下个月会更清楚一点"
    },
    {
      "start": 111.92,
      "end": 113.68,
      "text": "航天电器一旦真正放亮"
    },
    {
      "start": 113.68,
      "end": 114.6,
      "text": "受影响最大的"
    },
    {
      "start": 114.6,
      "end": 116.04,
      "text": "就是原来的存量供应商"
    },
    {
      "start": 116.04,
      "end": 118.52,
      "text": "这里面华峰科技的份额会被切走一部分"
    },
    {
      "start": 118.52,
      "end": 120.4,
      "text": "但清洪电子受到的冲击会更大"
    },
    {
      "start": 120.4,
      "end": 123.2,
      "text": "也就是说连接器这条线不是原缝不动的"
    },
    {
      "start": 123.2,
      "end": 124.68,
      "text": "新的供应商已经进来了"
    },
    {
      "start": 124.68,
      "end": 126.36,
      "text": "只是份额重拍还在发生"
    },
    {
      "start": 126.36,
      "end": 127.4,
      "text": "最后看光磨块"
    },
    {
      "start": 127.4,
      "end": 129.0,
      "text": "这个环节反而是变化最小的"
    },
    {
      "start": 129.0,
      "end": 131.32,
      "text": "深藤这边目前主要的光磨块供应商"
    },
    {
      "start": 131.32,
      "end": 133.28,
      "text": "还是华工科技和光讯科技"
    },
    {
      "start": 133.28,
      "end": 134.6,
      "text": "这个格局没有太大变化"
    },
    {
      "start": 134.6,
      "end": 136.0,
      "text": "如果再往800G去看"
    },
    {
      "start": 136.0,
      "end": 138.4,
      "text": "主力供应商则是华工科技和中继续创"
    },
    {
      "start": 138.4,
      "end": 140.2,
      "text": "所以你会发现光磨块这一块"
    },
    {
      "start": 140.2,
      "end": 142.24,
      "text": "不像连接器那样还在明显洗牌"
    },
    {
      "start": 142.24,
      "end": 144.56,
      "text": "线阶段主供名单其实已经比较清楚了"
    },
    {
      "start": 144.56,
      "end": 146.08,
      "text": "所以把这次段核在一起看"
    },
    {
      "start": 146.08,
      "end": 147.8,
      "text": "深藤现在这条核心供应链"
    },
    {
      "start": 147.8,
      "end": 149.68,
      "text": "封装这边是盛核金微"
    },
    {
      "start": 149.68,
      "end": 151.12,
      "text": "通负取良"
    },
    {
      "start": 151.12,
      "end": 154.56,
      "text": "盛核金微当前最重取良是后面重点扶持的方向"
    },
    {
      "start": 154.56,
      "end": 156.12,
      "text": "测试这边是偽测为主"
    },
    {
      "start": 156.12,
      "end": 157.76,
      "text": "常天科技和通负补位"
    },
    {
      "start": 157.76,
      "end": 159.64,
      "text": "设备端更依赖长穿科技"
    },
    {
      "start": 159.64,
      "end": 160.52,
      "text": "连接器这边"
    },
    {
      "start": 160.52,
      "end": 161.72,
      "text": "原有格局在松动"
    },
    {
      "start": 161.72,
      "end": 163.28,
      "text": "航天电器已经进场"
    },
    {
      "start": 163.28,
      "end": 165.16,
      "text": "华封科技和清洪电子的份额"
    },
    {
      "start": 165.16,
      "end": 166.12,
      "text": "会被重新分"
    },
    {
      "start": 166.12,
      "end": 167.76,
      "text": "光磨块这边则相对稳定"
    },
    {
      "start": 167.76,
      "end": 169.0,
      "text": "主要还是华工科技"
    },
    {
      "start": 169.0,
      "end": 169.84,
      "text": "光讯科技"
    },
    {
      "start": 169.84,
      "end": 170.72,
      "text": "到了800G"
    },
    {
      "start": 170.72,
      "end": 172.56,
      "text": "主力是华工科技和中继续创"
    },
    {
      "start": 172.56,
      "end": 173.12,
      "text": "说白了"
    },
    {
      "start": 173.12,
      "end": 175.08,
      "text": "深藤这条线现在不是没有变化"
    },
    {
      "start": 175.08,
      "end": 177.12,
      "text": "而是不同环节变化节奏不一样"
    },
    {
      "start": 177.12,
      "end": 178.4,
      "text": "封装在调结构"
    },
    {
      "start": 178.4,
      "end": 179.6,
      "text": "测试在文主力"
    },
    {
      "start": 179.6,
      "end": 181.16,
      "text": "连接器再换份额"
    },
    {
      "start": 181.16,
      "end": 182.52,
      "text": "光磨块烦到最稳"
    }
  ]
}