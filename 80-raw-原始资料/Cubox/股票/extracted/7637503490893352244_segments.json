      "start": 345.96,
      "end": 350.76,
      "text": "是国产存储走向全球中高端市场的代表性企业"
    },
    {
      "start": 350.76,
      "end": 353.08,
      "text": "他跟摆为存储得名力不一样"
    },
    {
      "start": 353.08,
      "end": 355.44,
      "text": "那两家是单一品类增长较快"
    },
    {
      "start": 355.44,
      "end": 358.92,
      "text": "他是全品类布局加全球市场拓展"
    },
    {
      "start": 358.92,
      "end": 360.64,
      "text": "手机 电脑 车载"
    },
    {
      "start": 360.64,
      "end": 362.28,
      "text": "AI服务器存储"
    },
    {
      "start": 362.28,
      "end": 363.52,
      "text": "他全都做"
    },
    {
      "start": 363.52,
      "end": 365.96,
      "text": "也是国内叫早将高端存储"
    },
    {
      "start": 365.96,
      "end": 368.96,
      "text": "打入欧美东南亚市场的品牌"
    },
    {
      "start": 368.96,
      "end": 370.44,
      "text": "去年行业韩东"
    },
    {
      "start": 370.44,
      "end": 372.44,
      "text": "海外巨头都在砍产能"
    },
    {
      "start": 372.44,
      "end": 375.16,
      "text": "裁员 同行都在收缩保命"
    },
    {
      "start": 375.16,
      "end": 378.36,
      "text": "他反而逆世砸钱搞研发 扩产能"
    },
    {
      "start": 378.36,
      "end": 381.28,
      "text": "还跟国内的长江存储深度绑定"
    },
    {
      "start": 381.28,
      "end": 382.52,
      "text": "打磨技术"
    },
    {
      "start": 382.52,
      "end": 383.92,
      "text": "今年行业一回暖"
    },
    {
      "start": 383.92,
      "end": 385.96,
      "text": "存储价格一掌 需求一报"
    },
    {
      "start": 385.96,
      "end": 389.28,
      "text": "他直接把之前丢的市场全抢回来了"
    },
    {
      "start": 389.28,
      "end": 393.2,
      "text": "还打进了之前被老外垄断的高端车载存储"
    },
    {
      "start": 393.2,
      "end": 395.12,
      "text": "企业级存储市场"
    },
    {
      "start": 395.12,
      "end": 397.6,
      "text": "相当于别人在寒东里都冬眠了"
    },
    {
      "start": 397.6,
      "end": 399.4,
      "text": "他在寒东里练肌肉"
    },
    {
      "start": 399.4,
      "end": 400.24,
      "text": "春天一来"
    },
    {
      "start": 400.24,
      "end": 402.32,
      "text": "他直接跑成了第一名"
    },
    {
      "start": 402.72,
      "end": 405.32,
      "text": "他的逆习不只是一家公司的翻身"
    },
    {
      "start": 405.32,
      "end": 407.4,
      "text": "更是国产存储品牌"
    },
    {
      "start": 407.4,
      "end": 410.12,
      "text": "打破海外几十年垄断的标志"
    },
    {
      "start": 410.12,
      "end": 412.88,
      "text": "这也是他能排第一的核心原因"
    },
    {
      "start": 412.88,
      "end": 414.8,
      "text": "看完这十家公司你会发现"
    },
    {
      "start": 414.8,
      "end": 416.4,
      "text": "他们能实现业绩增长"
    },
    {
      "start": 416.4,
      "end": 418.24,
      "text": "核心就三个点"
    },
    {
      "start": 418.24,
      "end": 420.48,
      "text": "一 提前 提前布局塞到"
    },
    {
      "start": 420.48,
      "end": 421.84,
      "text": "不是跟风吵提采"
    },
    {
      "start": 421.84,
      "end": 423.4,
      "text": "而是风口没来之前"
    },
    {
      "start": 423.4,
      "end": 425.84,
      "text": "就已经布局好了技术和产能"
    },
    {
      "start": 425.84,
      "end": 428.56,
      "text": "风口一来能够直接占据有力位置"
    },
    {
      "start": 428.56,
      "end": 430.52,
      "text": "二 有独家硬技术"
    },
    {
      "start": 430.52,
      "end": 432.36,
      "text": "别人做不出来的东西"
    },
    {
      "start": 432.36,
      "end": 434.72,
      "text": "他能做就能避开价格战"
    },
    {
      "start": 434.72,
      "end": 437.2,
      "text": "赚别人赚不到的高利润"
    },
    {
      "start": 437.2,
      "end": 439.68,
      "text": "三 逆世扛住周期"
    },
    {
      "start": 439.68,
      "end": 442.12,
      "text": "行业寒东的时候别人都在保命"
    },
    {
      "start": 442.12,
      "end": 443.72,
      "text": "他在逆世搞研发"
    },
    {
      "start": 443.72,
      "end": 445.92,
      "text": "扩产能 等行业回暖"
    },
    {
      "start": 445.92,
      "end": 448.0,
      "text": "同行 没货 没技术"
    },
    {
      "start": 448.0,
      "end": 451.16,
      "text": "他直接吃满整个行业的红利"
    },
    {
      "start": 451.16,
      "end": 452.28,
      "text": "对普通人来说"
    },
    {
      "start": 452.28,
      "end": 453.76,
      "text": "别光看涨了多少倍"
    },
    {
      "start": 453.76,
      "end": 455.2,
      "text": "也别听人吹概念"
    },
    {
      "start": 455.2,
      "end": 457.36,
      "text": "先搞懂他靠什么赚钱"
    },
    {
      "start": 457.36,
      "end": 459.64,
      "text": "和同行比 抢在哪"
    },
    {
      "start": 459.64,
      "end": 460.76,
      "text": "想明白这两点"
    },
    {
      "start": 460.76,
      "end": 462.8,
      "text": "机会才真正和你有关系"
    }
  ]
}